# Copy to .env and fill in only what you need. Everything defaults to offline
# "mock" providers, so the whole agent runs with NONE of these set.

# --- provider selection: mock (offline) | real adapter ---
VOX_STT=mock          # mock | deepgram
VOX_LLM=mock          # mock | groq | openai
VOX_TTS=mock          # mock | cartesia | elevenlabs
VOX_STATE=memory      # memory | redis

# --- audio / endpointing ---
VOX_SAMPLE_RATE=16000
VOX_FRAME_MS=20
VOX_VAD_THRESHOLD=500
VOX_VAD_END_SILENCE_MS=480

# --- dialog ---
VOX_SCENARIO=receptionist
VOX_CTX_TURNS=10
VOX_REDACT_PII=1

# --- model names ---
VOX_LLM_MODEL=llama-3.1-8b-instant
VOX_TTS_VOICE=default

# --- API keys (only read by the matching real adapter) ---
DEEPGRAM_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=
REDIS_URL=redis://localhost:6379/0
